# Supabase(プロジェクト設定 > API から取得)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー側のみで使用。絶対にNEXT_PUBLIC_を付けずクライアントに露出させない
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# trueにすると、Claude APIを実際には呼ばずダミー応答を返す開発用モード。
# Anthropicの課金設定(console.anthropic.com、claude.aiの契約とは別課金)がまだの間はtrueにしておく。
# 課金設定が終わったらfalseにする。
CLAUDE_MOCK=true

# Google OAuth(ログイン用。Supabase Auth側のProviders設定にも同じ値を登録する)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Docs/Sheets/Drive API(Phase2以降で使用。MVPでは未使用でも空のままでOK)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
